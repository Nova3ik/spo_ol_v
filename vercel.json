{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "sh build.sh",
  "functions": {
    "config/wsgi.py": {
      "excludeFiles": "{.vercel-venv/**,.venv/**,venv/**,static/**,staticfiles/**,staticfiles_build/**,__pycache__/**,app/tests.py,README.md,build.sh,db.sqlite3}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/config/wsgi.py"
    }
  ]
}
